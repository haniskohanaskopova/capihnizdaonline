name: Automatická kontrola a oprava čapích hnízd

on:
  schedule:
    # 1× denně. UTC → v létě 7:00, v zimě 6:00 (Praha).
    - cron: '0 5 * * *'
  workflow_dispatch:

jobs:
  check-nests:
    runs-on: ubuntu-latest
    permissions:
      contents: write   # nutné, aby bot mohl commitnout opravený nests.json
      issues: write     # záložní GitHub Issue
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Instalace nodemailer
        run: npm install nodemailer

      - name: Kontrola hnízd a automatická oprava
        env:
          YT_API_KEY: ${{ secrets.YT_API_KEY }}
          NOTIFY_EMAIL: ${{ secrets.NOTIFY_EMAIL }}
          SMTP_USER: ${{ secrets.SMTP_USER }}
          SMTP_PASS: ${{ secrets.SMTP_PASS }}
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: node check-nests.js

      - name: Commit oprav (jen když se něco změnilo)
        run: |
          if [[ -n "$(git status --porcelain nests.json check-state.json)" ]]; then
            git config user.name "Čapí bot"
            git config user.email "actions@users.noreply.github.com"
            git add nests.json check-state.json
            git commit -m "🤖 Auto-oprava streamů – $(TZ='Europe/Prague' date +'%Y-%m-%d %H:%M')"
            git pull --rebase origin main
            git push
            echo "Změny pushnuty, Cloudflare nasadí web."
          else
            echo "Žádné změny – nic se necommituje."
          fi
